@inherits Microsoft.AspNetCore.Components.ComponentBase
@using DBL
@using Models
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage Session
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer
@page "/updateConsumer"

<style>
    :root {
        --dream-purple: #9d4edd;
        --dream-pink: #ff00ff;
        --dream-blue: #4361ee;
        --nightmare-red: #ff003c;
        --star-glow: #ffffff;
        --void-dark: #0a0015;
    }

    body {
        background-color: var(--void-dark);
        margin: 0;
        padding: 0;
        overflow: hidden;
        font-family: 'Georgia', serif;
    }

    #canvas-background {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
    }

    /* Fixed Back Button at Top */
    .nav-header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        padding: 20px;
        display: flex;
        justify-content: flex-start;
        z-index: 100;
    }

    .btn-back {
        background: rgba(157, 78, 221, 0.15);
        border: 2px solid var(--dream-purple);
        color: var(--star-glow);
        padding: 10px 25px;
        cursor: pointer;
        text-transform: uppercase;
        font-weight: bold;
        transition: all 0.3s;
        letter-spacing: 2px;
        border-radius: 10px;
        box-shadow: 0 0 15px rgba(157, 78, 221, 0.3);
    }

        .btn-back:hover {
            background: linear-gradient(135deg, var(--dream-purple), var(--dream-pink));
            color: white;
            box-shadow: 0 0 30px rgba(157, 78, 221, 0.6);
            transform: translateY(-2px);
        }

    .page-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100vh;
        z-index: 1;
    }

    /* Dream Portal Card */
    .update-card {
        background: linear-gradient(135deg, rgba(157, 78, 221, 0.25), rgba(67, 97, 238, 0.2));
        backdrop-filter: blur(30px);
        border: 2px solid var(--dream-purple);
        border-radius: 25px;
        padding: 50px 45px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 25px;
        box-shadow: 0 0 50px rgba(157, 78, 221, 0.4), inset 0 0 30px rgba(157, 78, 221, 0.1);
        width: 480px;
    }

    .glitch-title {
        font-size: 3rem;
        color: var(--star-glow);
        text-transform: uppercase;
        position: relative;
        animation: dream-drift 2s infinite ease-in-out;
        margin: 0;
        letter-spacing: 6px;
        text-shadow: 0 0 20px var(--dream-pink), 0 0 40px var(--dream-purple);
    }

        .glitch-title::before, .glitch-title::after {
            content: attr(data-text);
            position: absolute;
            top: 0;
            left: 0;
            opacity: 0.6;
        }

        .glitch-title::before {
            color: var(--dream-pink);
            z-index: -1;
            animation: title-glitch 0.4s infinite;
        }

        .glitch-title::after {
            color: var(--dream-blue);
            z-index: -2;
            animation: title-glitch 0.4s reverse infinite;
        }

    .input1 {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 2px solid rgba(157, 78, 221, 0.5);
        color: var(--star-glow);
        padding: 18px;
        font-size: 1.1rem;
        outline: none;
        transition: 0.3s;
        border-radius: 12px;
        font-family: 'Georgia', serif;
    }

        .input1:focus {
            border-color: var(--dream-pink);
            box-shadow: 0 0 25px rgba(157, 78, 221, 0.4), inset 0 0 15px rgba(157, 78, 221, 0.1);
            background: rgba(157, 78, 221, 0.1);
        }

    .button1 {
        background: linear-gradient(135deg, var(--dream-purple), var(--dream-blue));
        color: var(--star-glow);
        border: none;
        padding: 18px 40px;
        cursor: pointer;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 3px;
        transition: all 0.3s;
        border-radius: 12px;
        box-shadow: 0 0 25px rgba(157, 78, 221, 0.5);
        font-size: 1rem;
    }

        .button1:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 40px rgba(157, 78, 221, 0.7), 0 0 60px rgba(255, 0, 255, 0.4);
            background: linear-gradient(135deg, var(--dream-pink), var(--dream-purple));
        }

    .response-text {
        color: var(--nightmare-red);
        font-size: 0.95rem;
        margin-top: 15px;
        min-height: 1.4rem;
        text-shadow: 0 0 10px rgba(255, 0, 60, 0.5);
        font-weight: 600;
    }

    @@keyframes dream-drift {
        0%, 100% { transform: translateX(0); }
        50% { transform: translateX(4px); }
    }

    @@keyframes title-glitch {
        0% { transform: translate(0); }
        20% { transform: translate(-2px, 2px); }
        40% { transform: translate(2px, -2px); }
        100% { transform: translate(0); }
    }
</style>

<canvas id="canvas-background"></canvas>

<!-- Top Navigation -->
<div class="nav-header">
    <button class="btn-back" @onclick="GoBackToMain">Main Page</button>
</div>

<div class="page-container">
    <div class="update-card">
        <h1 class="glitch-title" data-text="Update User">Update User</h1>

        <input placeholder="Username" class="input1" @bind-value="username" />

        <button id="update-btn" class="button1" @onclick="UpdateAsync">Update</button>
   
        <div class="response-text">@response</div>
    </div>
</div>

@code {
    string username;
    string response;
    Consumer con;
    private IJSObjectReference? module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize background module
            module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/updateBackground.js");
            await module.InvokeVoidAsync("initFuturisticBackground", new[] { "SECURE", "UPDATE", "USER", "SYSTEM" });

            // Retrieve session data
            var s = await Session.GetAsync<Consumer>("consumer");
            if (s.Success)
            {
                con = s.Value;
                username = con.Username; // Pre-fill username
                StateHasChanged();
            }
            else
            {
                NavigationManager.NavigateTo("/",forceLoad:true);
            }
        }
    }

    async Task UpdateAsync()
    {
        ConsumerDB dB = new ConsumerDB();
        if (con != null)
        {
            foreach (var item in (await dB.GetAllAsync()))
            {
                if (item.Username == username && item.Id != con.Id)
                {
                    response = "Username already taken";
                    return;
                }
            }

            con.Username = username;
            await dB.UpdateAsync(con);

            // Save updated consumer back to session
            await Session.SetAsync("consumer", con);
            response = "User Updated successfully";

            if (module != null)
            {
                await module.InvokeVoidAsync("triggerSuccessWave", "update-btn");
            }
        }
    }

    private void GoBackToMain()
    {
        
        NavigationManager.NavigateTo("/");
    }
}
